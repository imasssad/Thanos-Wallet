{
  "name": "thanos-wallet-monorepo",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build":     "turbo run build",
    "dev":       "turbo run dev --parallel",
    "lint":      "eslint --max-warnings 500 \"apps/**/*.{ts,tsx,js}\" \"packages/**/src/**/*.{ts,tsx,js}\" \"services/**/src/**/*.{ts,tsx,js}\"",
    "lint:fix":  "eslint --fix \"apps/**/*.{ts,tsx,js}\" \"packages/**/src/**/*.{ts,tsx,js}\" \"services/**/src/**/*.{ts,tsx,js}\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js":                       "^10.0.1",
    "@next/eslint-plugin-next":         "^15.0.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "eslint":                           "^9.13.0",
    "eslint-plugin-jsx-a11y":           "^6.10.2",
    "eslint-plugin-react-hooks":        "^5.0.0",
    "globals":                          "^15.11.0",
    "typescript-eslint":                "^8.10.0",
    "turbo":                            "^2.1.3",
    "typescript":                       "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.16.0",
      "@xmldom/xmldom": ">=0.9.8",
      "bigint-buffer": ">=1.1.5",
      "protobufjs": ">=7.5.6",
      "tar": ">=7.5.11",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-3gc7-fjrx-p6mg"
      ]
    }
  }
}

