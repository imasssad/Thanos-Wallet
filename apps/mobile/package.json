{
  "name": "@thanos/mobile",
  "version": "0.2.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "release:ios": "eas build --platform ios --profile production",
    "release:android": "eas build --platform android --profile production",
    "release:all": "eas build --platform all --profile production --non-interactive",
    "apk": "eas build --platform android --profile production-apk",
    "apk:ci": "eas build --platform android --profile production-apk --non-interactive",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest",
    "submit:all": "eas submit --platform all --profile production --latest --non-interactive",
    "deploy:ios": "eas build --platform ios --profile production --non-interactive --auto-submit",
    "deploy:android": "eas build --platform android --profile production --non-interactive --auto-submit",
    "deploy:all": "eas build --platform all --profile production --non-interactive --auto-submit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@cosmjs/crypto": "^0.39.0",
    "@cosmjs/encoding": "^0.39.0",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@expo/metro-runtime": "~5.0.5",
    "@litho/multx-sdk": "file:./vendor/litho-multx-sdk-0.2.0.tgz",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^2.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@reown/walletkit": "^1.5.5",
    "@scure/base": "^1.1.9",
    "@scure/bip32": "^1.5.0",
    "@scure/bip39": "^1.4.0",
    "@scure/btc-signer": "^1.5.0",
    "@sentry/react-native": "6.14.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.98.0",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/react-native-compat": "^2.23.9",
    "ethers": "^6.13.4",
    "ethers5": "npm:ethers@5.8.0",
    "expo": "53.0.27",
    "expo-build-properties": "~0.14.8",
    "expo-camera": "~16.1.11",
    "expo-clipboard": "~7.1.5",
    "expo-device": "~7.1.4",
    "expo-font": "~13.3.2",
    "expo-local-authentication": "~16.0.5",
    "expo-notifications": "~0.31.4",
    "expo-screen-capture": "~7.2.0",
    "expo-secure-store": "~14.2.4",
    "lucide-react-native": "^1.25.0",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.2.7",
    "react-native": "0.79.6",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "~4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.2.7",
    "@types/react": "~19.0.10"
  }
