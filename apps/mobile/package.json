{
  "name": "@thanos/mobile",
  "version": "0.2.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "release:ios": "eas build --platform ios --profile production",
    "release:android": "eas build --platform android --profile production",
    "release:all": "eas build --platform all --profile production --non-interactive",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest",
    "submit:all": "eas submit --platform all --profile production --latest --non-interactive",
    "deploy:ios": "eas build --platform ios --profile production --non-interactive --auto-submit",
    "deploy:android": "eas build --platform android --profile production --non-interactive --auto-submit",
    "deploy:all": "eas build --platform all --profile production --non-interactive --auto-submit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~4.0.1",
    "@cosmjs/crypto": "^0.32.4",
    "@cosmjs/encoding": "^0.32.4",
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^2.1.0",
    "@scure/base": "^1.1.9",
    "@scure/bip32": "^1.5.0",
    "@scure/bip39": "^1.4.0",
    "@scure/btc-signer": "^1.5.0",
    "@solana/web3.js": "^1.98.0",
    "@solana/spl-token": "^0.4.8",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@reown/walletkit": "^1.5.5",
    "@walletconnect/core": "^2.23.9",
    "@walletconnect/react-native-compat": "^2.23.9",
    "ethers": "^6.13.4",
    "expo": "~52.0.11",
    "expo-camera": "~16.0.18",
    "expo-clipboard": "~7.0.1",
    "expo-device": "~7.0.3",
    "expo-local-authentication": "~15.0.1",
    "expo-notifications": "~0.29.14",
    "expo-screen-capture": "~7.0.1",
    "expo-secure-store": "~14.0.1",
    "@sentry/react-native": "~6.3.0",
    "lucide-react-native": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}
