# EAS runs a plain `npm install`, which enforces strict peer resolution.
# The vendored @litho/multx-sdk-0.2.0.tgz declares peerOptional react@^18,
# which conflicts with React 19 (Expo SDK 53) and fails the Install
# dependencies phase. legacy-peer-deps matches how the lockfile was
# produced locally. Native peers we actually need (e.g. netinfo) are
# declared as direct dependencies, so nothing real is lost.
legacy-peer-deps=true
