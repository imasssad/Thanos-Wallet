{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EAS_NO_VCS": "1",
        "EXPO_PUBLIC_ENV": "production",
        "NODE_ENV": "production"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "image": "latest",
        "cache": { "disabled": false },
        "credentialsSource": "local"
      }
    },
    "production-apk": { "extends": "preview" },
    "ios-simulator": {
      "extends": "preview",
      "ios": { "simulator": true }
    },
    "production": {
      "node": "20.19.4",
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "NODE_ENV": "production"
      },
      "ios": {
        "distribution": "store",
        "image": "sdk-52",
        "autoIncrement": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle",
        "image": "latest",
        "autoIncrement": false,
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId":     "imasssadk@gmail.com",
        "ascAppId":    "6738206983",
        "appleTeamId": "JEYAFQ92YG"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-service-account.json",
        "track":                 "production",
        "releaseStatus":         "draft"
      }
    },
    "preview": {
      "android": {
        "serviceAccountKeyPath": "./credentials/play-service-account.json",
        "track":                 "internal"
      }
    }
  }
}
