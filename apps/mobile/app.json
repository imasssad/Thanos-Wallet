{
  "expo": {
    "name": "Thanos Wallet",
    "slug": "thanos-wallet",
    "scheme": "thanoswallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/Thanos_Logo_Transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "ai.thanos.wallet",
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Thanos Wallet uses the camera to scan QR codes for wallet addresses and WalletConnect pairing.",
        "NSFaceIDUsageDescription": "Thanos Wallet uses Face ID to unlock your wallet quickly and securely.",
        "NSLocalNetworkUsageDescription": "Thanos Wallet connects to local nodes when you configure a custom RPC endpoint.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:thanos.fi"]
    },
    "android": {
      "package": "ai.thanos.wallet",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Thanos_Logo_Transparent.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [{ "scheme": "thanoswallet" }, { "scheme": "wc" }]
        }
      ]
    },
    "jsEngine": "hermes",
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Thanos Wallet uses the camera to scan QR codes for wallet addresses and WalletConnect pairing."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableBundleCompression": true,
            "extraProguardRules": "-keep class com.facebook.hermes.unicode.** { *; }\n-keep class com.facebook.jni.** { *; }",
            "buildTypes": {
              "release": {
                "minifyEnabled": true,
                "shrinkResources": true,
                "proguardFiles": ["proguard-android-optimize.txt", "proguard-rules.pro"]
              }
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "edaba20e-25dd-41e5-85ae-76872c092d1e"
      }
    },
    "owner": "imasssad"
  }
}
