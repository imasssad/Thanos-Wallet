{
  "expo": {
    "name": "Thanos Wallet",
    "slug": "thanos-wallet",
    "scheme": "thanoswallet",
    "version": "1.0.3",
    "jsEngine": "hermes",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/Thanos_Logo_Transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#080809"
    },
    "ios": {
      "bundleIdentifier": "litho.thanos.wallet",
      "supportsTablet": true,
      "buildNumber": "8",
      "infoPlist": {
        "NSCameraUsageDescription": "Thanos Wallet uses the camera to scan QR codes for wallet addresses and WalletConnect pairing.",
        "NSFaceIDUsageDescription": "Thanos Wallet uses Face ID to unlock your wallet quickly and securely.",
        "NSLocalNetworkUsageDescription": "Thanos Wallet connects to local nodes when you configure a custom RPC endpoint.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "walletconnect",
            "CFBundleURLSchemes": [
              "wc"
            ]
          }
        ]
      },
      "associatedDomains": [
        "applinks:thanos.fi"
      ]
    },
    "android": {
      "package": "ai.thanos.wallet",
      "googleServicesFile": "./google-services.json",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Thanos_Logo_Transparent.png",
        "backgroundColor": "#080809"
      },
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "INTERNET",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "thanoswallet"
            },
            {
              "scheme": "wc"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Thanos Wallet uses Face ID to unlock your wallet quickly and securely."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/litho-sym.ttf",
            "./assets/fonts/Satoshi-Regular.ttf",
            "./assets/fonts/Satoshi-Medium.ttf",
            "./assets/fonts/Satoshi-Bold.ttf"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Thanos Wallet uses the camera to scan QR codes for wallet addresses and WalletConnect pairing.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "enableBundleCompression": false,
            "extraMavenRepos": [
              "https://jitpack.io"
            ]
          }
        }
      ],
      "./plugins/withFmtConstevalFix"
    ],
    "extra": {
      "eas": {
        "projectId": "edaba20e-25dd-41e5-85ae-76872c092d1e"
      }
    },
    "owner": "imasssad"
  }
}
