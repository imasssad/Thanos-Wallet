{
  "name": "@thanos/extension",
  "version": "0.2.0",
  "private": true,
  "description": "Thanos Wallet — Lithosphere-first browser extension with Bitcoin, Solana, MultX bridge, Ignite DEX and dApp EIP-1193 provider.",
  "homepage": "https://thanos.fi",
  "author": {
    "name": "Thanos Wallet",
    "email": "devs@thanos.fi"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/imasssad/Thanos-Wallet.git"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:safari": "wxt zip -b safari",
    "safari:convert": "bash safari/convert.sh",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@reown/walletkit": "^1.5.5",
    "@thanos/api-client": "workspace:*",
    "@thanos/sdk-core": "workspace:^",
    "@walletconnect/core": "^2.21.6",
    "@walletconnect/types": "^2.21.6",
    "ethers": "^6.13.4",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.14.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wxt": "^0.19.18"
  }
}
