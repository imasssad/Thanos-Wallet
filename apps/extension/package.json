{
  "name": "@thanos/extension",
  "version": "0.9.22",
  "private": true,
  "description": "Thanos Wallet — Lithosphere-first browser extension with Bitcoin, Solana, MultX bridge, Ignite DEX and dApp EIP-1193 provider.",
  "homepage": "https://thanos.fi",
  "author": {
    "name": "Thanos Wallet",
    "email": "devs@thanos.fi"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/imasssad/Thanos-Wallet.git"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:safari": "wxt zip -b safari",
    "safari:convert": "bash safari/convert.sh",
    "safari:archive": "bash safari/archive.sh",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@cosmjs/crypto": "^0.32.4",
    "@cosmjs/encoding": "^0.32.4",
    "@cosmjs/proto-signing": "^0.32.4",
    "@cosmjs/stargate": "^0.32.4",
    "@litho/multx-sdk": "file:../../vendor/litho-multx-sdk-0.2.0.tgz",
    "@reown/walletkit": "^1.5.5",
    "@solana/web3.js": "^1.98.0",
    "@thanos/api-client": "workspace:*",
    "@thanos/sdk-core": "workspace:^",
    "@walletconnect/core": "^2.21.6",
    "@walletconnect/types": "^2.21.6",
    "bip32": "^5.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.6",
    "ecpair": "^3.0.0",
    "ethers": "^6.13.4",
    "ethers5": "npm:ethers@5.8.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tiny-secp256k1": "^2.2.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wxt": "^0.19.18"
  }
}
