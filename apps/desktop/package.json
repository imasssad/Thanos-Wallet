{
  "name": "@thanos/desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Thanos Wallet — Lithosphere-first desktop wallet with Bitcoin, Solana, MultX bridge, Ignite DEX and hardware-wallet support.",
  "homepage": "https://thanos.fi",
  "author": {
    "name": "Thanos Wallet",
    "email": "devs@thanos.fi"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/imasssad/Thanos-Wallet.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.main.json\" \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "echo 'no lint configured'",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@ledgerhq/hw-app-eth": "^6.46.0",
    "@ledgerhq/hw-transport-webhid": "^6.31.5",
    "@reown/walletkit": "^1.5.5",
    "@thanos/api-client": "workspace:*",
    "@thanos/sdk-core": "workspace:*",
    "@trezor/connect-web": "^9.7.1",
    "@walletconnect/core": "^2.21.6",
    "@walletconnect/types": "^2.21.6",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "ethers": "^6.13.4",
    "hash-wasm": "^4.12.0",
    "keytar": "^7.9.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "wait-on": "^8.0.1"
  }
}