{
  "name": "@thanos/desktop",
  "version": "0.2.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -w -p tsconfig.main.json\" \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "echo 'no lint configured'",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@thanos/api-client": "workspace:*",
    "@thanos/sdk-core": "workspace:*",
    "electron": "^33.2.1",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "ethers": "^6.13.4",
    "hash-wasm": "^4.12.0",
    "keytar": "^7.9.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}