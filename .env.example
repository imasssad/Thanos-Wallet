# =============================================================================
# THANOS WALLET — ENVIRONMENT VARIABLES
# Copy this to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=thanos_wallet
POSTGRES_USER=thanos
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://thanos:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/thanos_wallet

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379

# ─── Auth / JWT ────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ─── Lithosphere / Makalu RPC ──────────────────────────────────────────────
LITHO_RPC_PRIMARY=https://rpc.litho.ai
LITHO_RPC_FALLBACK=https://rpc-fallback.litho.ai
LITHO_CHAIN_ID=700777
KAMET_RPC_PRIMARY=https://rpc-kamet.litho.ai
KAMET_CHAIN_ID=700778

# ─── Other Chain RPCs ──────────────────────────────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com
BNB_RPC_URL=https://bsc-dataseed.binance.org
BTC_RPC_URL=https://blockstream.info/api
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# ─── LEP100 Contract Addresses (Makalu Testnet) ────────────────────────────
# Get verified addresses from the Makalu explorer: https://makalu.litho.ai
MAKALU_LEP100_WLITHO_ADDRESS=0xEB6cfcC84F35D6b20166cD6149Fed712ED2a7Cfe
MAKALU_LEP100_LAX_ADDRESS=0x9611436ea7B4764Eeb1E31B83A5bF03c835Eb3e8
MAKALU_LEP100_JOT_ADDRESS=0x8187b232BDa461d17EA519Ba6898F7b220AAf2e2
MAKALU_LEP100_COLLE_ADDRESS=0xE7eBf52bD714348984Fb00b4c99d9e994D60DF49
MAKALU_LEP100_IMAGE_ADDRESS=0x7a29252B13367800dD78FED47afFaB86a615c844
MAKALU_LEP100_AGII_ADDRESS=0x9984ad7a774218B263D74BD8A5FFEDa7DD6Fe020
MAKALU_LEP100_BLDR_ADDRESS=0x07039884740F4DB0f71BD3bCF87a3FfA0B85A26F
MAKALU_LEP100_FGPT_ADDRESS=0xa25c2a49893B0296977E2E70Da56AF47241d592F
MAKALU_LEP100_MUSA_ADDRESS=0xDEE12eD9C5A1F7c29f3ab3961B892a8434A97EFa

# ─── MultX (Swap / Bridge) ─────────────────────────────────────────────────
# Provide these once Esha shares the MultX API credentials
MULTX_API_URL=
MULTX_API_KEY=

# ─── WalletConnect ─────────────────────────────────────────────────────────
# Get project ID from: https://cloud.walletconnect.com
WALLETCONNECT_PROJECT_ID=

# ─── Pricing ───────────────────────────────────────────────────────────────
PRICE_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ─── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── App Ports ─────────────────────────────────────────────────────────────
API_PORT=4000
INDEXER_PORT=4010
