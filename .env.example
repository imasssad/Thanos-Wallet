# =============================================================================
# THANOS WALLET — ENVIRONMENT VARIABLES
# Copy this to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=thanos_wallet
POSTGRES_USER=thanos
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://thanos:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/thanos_wallet

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@localhost:6379

# ─── Auth / JWT ────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ─── Lithosphere / Makalu RPC ──────────────────────────────────────────────
# Makalu = mainnet (chain 700777). Kamet = sister chain for DNNS (chain 900523).
# Failover: every RPC consumer builds an ethers FallbackProvider over the
# primary + fallback — if the primary stalls (>1.5s) traffic rotates to the
# fallback transparently. The indexer prefers rpc-2 as its primary so its
# sync load doesn't compete with user traffic on rpc.litho.ai.
LITHO_RPC_PRIMARY=https://rpc.litho.ai
LITHO_RPC_FALLBACK=https://rpc-2.litho.ai
LITHO_RPC_INDEXER=https://rpc-2.litho.ai
LITHO_CHAIN_ID=700777
KAMET_RPC_PRIMARY=https://rpc.kamet.litho.ai
KAMET_RPC_FALLBACK=https://rpc-3.litho.ai
KAMET_CHAIN_ID=900523
# Web bundle reads the comma-separated Makalu list (primary,fallback).
NEXT_PUBLIC_LITHO_RPC=https://rpc.litho.ai,https://rpc-2.litho.ai

# ─── Other Chain RPCs ──────────────────────────────────────────────────────
ETH_RPC_URL=https://eth.llamarpc.com
BNB_RPC_URL=https://bsc-dataseed.binance.org
BTC_RPC_URL=https://blockstream.info/api
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# ─── LEP100 (standard ERC-20 + burn/burnFrom/owner) ────────────────────────
# Full ABI in repo: contracts/artifacts/contracts/LEP100Token.sol/LEP100Token.json
# Verified addresses: https://makalu.litho.ai
#
# Native (gas) coin — no token address:
#   LITHO https://makalu.litho.ai/token/native
#
# Lithosphere ecosystem LEP100 tokens (Makalu mainnet, chain 700777):
MAKALU_LEP100_LITBTC_ADDRESS=0xC4645CA5411D6E27556780AB4cdd0DF7e609df74
MAKALU_LEP100_JOT_ADDRESS=0xEF2f35f6d0fb7DC9E87b8ca8252AE2E6ffb2a25e
MAKALU_LEP100_LAX_ADDRESS=0x1Cde2Ca6c2ab8622003ebe06e382bC07850d4B8d
MAKALU_LEP100_COLLE_ADDRESS=0x10D4BB600c96e9243E2f50baFED8b247
MAKALU_LEP100_FURGPT_ADDRESS=0xDB829befCF8E582379E2c034FA2589b8D2EA1c5D

# Legacy / additional LEP100 addresses (kept for backwards compat):
MAKALU_LEP100_WLITHO_ADDRESS=0xEB6cfcC84F35D6b20166cD6149Fed712ED2a7Cfe
# IMAGE / Imagen Network — updated to the address provided by client
MAKALU_LEP100_IMAGE_ADDRESS=0xAcD98E323968647936887aD4934e64B01060727e
MAKALU_LEP100_AGII_ADDRESS=0x9984ad7a774218B263D74BD8A5FFEDa7DD6Fe020
MAKALU_LEP100_BLDR_ADDRESS=0x07039884740F4DB0f71BD3bCF87a3FfA0B85A26F
MAKALU_LEP100_FGPT_ADDRESS=0xa25c2a49893B0296977E2E70Da56AF47241d592F
MAKALU_LEP100_MUSA_ADDRESS=0xDEE12eD9C5A1F7c29f3ab3961B892a8434A97EFa

# ─── DNNS (decentralised name service, lives on Kamet chain 900523) ────────
# Schema-compatible with ENS. NameWrapper is the canonical entry point.
DNNS_NAME_WRAPPER_ADDRESS=0xc47E49259b8dDa2C9D57941E1a52747E4c721Cb9
DNNS_REGISTRY_ADDRESS=0x316dc15bF377F7187e5BE38BA19e673Ca823d1ab
DNNS_BASE_REGISTRAR_ADDRESS=0xB3D1a8e92FFAD73Ab8a07BF37A8E1374df8B3722
DNNS_METADATA_SERVICE_ADDRESS=0x9138E4CD9c5EBAc6964Fd28516BD5B0E83E5AA51
DNNS_METADATA_URI=https://names.litho.ai/metadata/{id}

# ─── MultX (Swap / Bridge — internal Litho service, no auth layer) ─────────
# No API key — the bridge is keyless. URL is fixed; only override for a
# staging bridge. NEXT_PUBLIC_MULTX_API_URL exposes it to the web bundle.
MULTX_API_URL=https://bridge.litho.ai
NEXT_PUBLIC_MULTX_API_URL=https://bridge.litho.ai

# ─── WalletConnect / ReOwn ─────────────────────────────────────────────────
# Get project ID from: https://cloud.reown.com  (formerly cloud.walletconnect.com)
WALLETCONNECT_PROJECT_ID=6d05d9a84112ca2f7c1bb77a76a18c81
REOWN_PROJECT_ID=6d05d9a84112ca2f7c1bb77a76a18c81
# Exposed to the browser bundle for the WalletConnect modal:
NEXT_PUBLIC_REOWN_PROJECT_ID=6d05d9a84112ca2f7c1bb77a76a18c81

# ─── Pricing ───────────────────────────────────────────────────────────────
PRICE_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ─── Monitoring ────────────────────────────────────────────────────────────
SENTRY_DSN=

# Alertmanager (ops/observability/docker-compose.observability.yml).
# Leave blank to disable that channel — the receiver silently no-ops.
# - Slack: create an incoming webhook at api.slack.com/apps → Incoming Webhooks.
# - PagerDuty: create an Events v2 integration on a service; use its "Integration Key".
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# ─── App Ports ─────────────────────────────────────────────────────────────
API_PORT=4000
INDEXER_PORT=4010
