{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Requests / s (5m)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"thanos-api\"}[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } }
    },
    {
      "type": "stat",
      "title": "Error ratio 4xx",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"thanos-api\",status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"thanos-api\"}[5m])), 1e-9)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 } }
    },
    {
      "type": "stat",
      "title": "Error ratio 5xx",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"thanos-api\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"thanos-api\"}[5m])), 1e-9)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red",    "value": 0.01 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "p99 latency (5m)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"thanos-api\"}[5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red",    "value": 1.0 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "timeseries",
      "title": "Request rate by route (top 10)",
      "id": 5,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (route) (rate(http_requests_total{job=\"thanos-api\"}[1m])))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "p95 latency by route (top 10)",
      "id": 6,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, histogram_quantile(0.95, sum by (route, le) (rate(http_request_duration_seconds_bucket{job=\"thanos-api\"}[5m]))))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Error rate by route (4xx + 5xx)",
      "id": 7,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(http_requests_total{job=\"thanos-api\",status_code=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Node.js heap & event-loop lag",
      "id": 8,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "heap",  "expr": "nodejs_heap_size_used_bytes{job=\"thanos-api\"}", "legendFormat": "heap used" },
        { "refId": "rss",   "expr": "process_resident_memory_bytes{job=\"thanos-api\"}", "legendFormat": "rss" },
        { "refId": "lag",   "expr": "nodejs_eventloop_lag_seconds{job=\"thanos-api\"}", "legendFormat": "event-loop lag" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "event-loop lag" }, "properties": [{ "id": "unit", "value": "s" }] }
        ]
      }
    }
  ],
