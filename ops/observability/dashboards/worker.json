{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Jobs / s (completed, 5m)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(thanos_worker_jobs_total{status=\"completed\"}[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } }
    },
    {
      "type": "stat",
      "title": "Jobs / s (failed, 5m)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(thanos_worker_jobs_total{status=\"failed\"}[5m]))" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red",    "value": 0.2 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Total wait depth",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(thanos_worker_queue_depth{state=\"wait\"})" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red",    "value": 100 }
            ]
          }
        }
      },
      "options": { "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Total failed (cumulative depth)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(thanos_worker_queue_depth{state=\"failed\"})" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "timeseries",
      "title": "Queue depth — wait",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "thanos_worker_queue_depth{state=\"wait\"}",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } } }
    },
    {
      "type": "timeseries",
      "title": "Queue depth — active / delayed / failed",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "thanos_worker_queue_depth{state=~\"active|delayed|failed\"}",
          "legendFormat": "{{queue}} / {{state}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Job throughput by queue + status",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue, status) (rate(thanos_worker_jobs_total[1m]))",
          "legendFormat": "{{queue}} / {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "showLegend": true, "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "Job duration p95 by queue (completed)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (queue, le) (rate(thanos_worker_job_duration_seconds_bucket{status=\"completed\"}[5m])))",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Failure ratio by queue (15m)",
      "id": 9,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rate(thanos_worker_jobs_total{status=\"failed\"}[15m])) / clamp_min(sum by (queue) (rate(thanos_worker_jobs_total[15m])), 1e-9)",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["thanos", "worker", "bullmq"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
