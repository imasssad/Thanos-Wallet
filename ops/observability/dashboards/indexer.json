      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 } } }
    },
    {
      "type": "timeseries",
      "title": "Cursor advance rate (blocks/s)",
