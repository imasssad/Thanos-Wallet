        { "refId": "p95", "expr": "histogram_quantile(0.95, sum by (le) (rate(thanos_worker_job_duration_seconds_bucket{queue=\"bridge-poll\"}[5m])))", "legendFormat": "p95" },
        { "refId": "p99", "expr": "histogram_quantile(0.99, sum by (le) (rate(thanos_worker_job_duration_seconds_bucket{queue=\"bridge-poll\"}[5m])))", "legendFormat": "p99" }
