node_modules/
.next/
dist/
dist-client/
build/
# electron-builder reads icon sources from apps/desktop/build/icons/ at
# release time — those files are deliberately tracked even though the
# blanket build/ rule above would otherwise ignore them.
!apps/desktop/build/
!apps/desktop/build/icons/
!apps/desktop/build/icons/**
coverage/

# Env / secrets
.env
.env.local
.env.*.local
*.key
*.pem

# OS
.DS_Store
Thumbs.db

# Build outputs
out/
.expo/
.expo-shared/
.wxt/
.output/
.turbo/
*.zip
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / tools
.vscode/
.idea/
.claude/
*.swp
*.swo

# Lockfile (project preference)
pnpm-lock.yaml

# Loose design assets (not source)
*.fig
19SHPQjQ.png
_fig_extract/

# Native / mobile artifacts
apps/mobile/android/app/build/
apps/mobile/ios/build/
apps/mobile/.gradle/
apps/desktop/release/

# Local asset working directory — coin icons, animations, mockups.
# Not part of the shipped source tree; lives in 1Password / Drive.
Thanos_Wallet_Pack/

# ─── Store-signing secrets (defense-in-depth) ─────────────────────────────
# The mobile credentials folder has its own .gitignore, but block the
# secret file types repo-wide too so a stray copy anywhere never lands
# in a commit.
apps/mobile/credentials/*
!apps/mobile/credentials/.gitignore
!apps/mobile/credentials/README.md
# EAS local credentials manifest (keystore paths + passwords) — never commit.
apps/mobile/credentials.json
# Downloaded build artifacts parked in the tree.
*.apk
*.aab
*.ipa
*.p8
*.jks
*.keystore
*.mobileprovision
*-service-account*.json
asc-api-key*.p8

# apps/mobile is workspace-detached and npm-locked for EAS - a stray pnpm-lock.yaml
# there makes EAS attempt (and fail) a pnpm install on every build before falling
# back, and risks resolving deps from a stale lockfile.
apps/mobile/pnpm-lock.yaml
