{
  "name": "thanos-connect",
  "version": "0.1.0",
  "description": "Drop-in Sign-In With Thanos integration — EIP-1193 + EIP-6963 discovery, SIWT flow, React + vanilla.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured'"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "thanos",
    "wallet",
    "auth",
    "siwe",
    "siwt",
    "sign-in-with-ethereum",
    "eip-1193",
    "eip-6963",
    "walletconnect",
    "lithosphere",
    "web3-auth"
  ],
  "homepage": "https://github.com/imasssad/Thanos-Wallet/tree/main/packages/connect",
  "bugs": {
    "url": "https://github.com/imasssad/Thanos-Wallet/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/imasssad/Thanos-Wallet.git",
    "directory": "packages/connect"
  },
  "publishConfig": {
    "access": "public"
  }
}
